{
  "name": "svg2tsx",
  "version": "1.0.0",
  "description": "CLI to turn SVGs into ready-to-use TSX React components",
  "type": "module",
  "bin": {
    "svg2tsx": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "svg",
    "tsx",
    "react",
    "icon",
    "component",
    "converter",
    "cli"
  ],
  "author": "SouravShrestha",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "domhandler": "^5.0.3",
    "glob": "^11.0.1",
    "htmlparser2": "^9.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
